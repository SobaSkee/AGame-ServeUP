PORT=3001
# update the following with your own API key (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=""
NODE_ENV=development

# MongoDB — optional for /api/* (Gemini). Required only for /recipes CRUD.
# Use a full URI, e.g. mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
# Leave DB_CONN_STRING unset or empty to run the API without Mongo.
DB_CONN_STRING=mongodb+srv://<db_username>:<db_password>@cluster0.rovhof6.mongodb.net/?appName=Cluster0
DB_NAME=serve_up
USERS_COLLECTION_NAME=users
RECIPES_COLLECTION_NAME=recipes
SAVED_RECIPES_COLLECTION_NAME=saved_recipes
INGREDIENT_SCANS_COLLECTION_NAME=ingredientScans
SCAN_RECIPES_COLLECTION_NAME=scan_recipes
API_PUBLIC_URL=http://localhost:3001
SPOONACULAR_API_KEY=
