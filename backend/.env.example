PORT=3001
# update the following with your own API key (https://aistudio.google.com/api-keys)
GEMINI_API_KEY=
NODE_ENV=development

# MongoDB — optional for /api/* (Gemini). Required only for /recipes CRUD.
# Use a full URI, e.g. mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
# Leave DB_CONN_STRING unset or empty to run the API without Mongo.
# DB_CONN_STRING=
DB_NAME=serve_up
RECIPES_COLLECTION_NAME=recipes

SPOONACULAR_API_KEY=
